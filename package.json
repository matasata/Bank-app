{
  "name": "add-game",
  "version": "0.1.0",
  "description": "AD&D 1st Edition Complete Game System",
  "main": "electron/main.js",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "electron-builder",
    "build:mac": "bash scripts/build-mac.sh",
    "build:win": "bash scripts/build-win.sh",
    "test": "cd backend && python -m pytest ../tests/ -v",
    "start": "electron ."
  },
  "dependencies": {
    "electron": "^28.1.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.add.game",
    "productName": "AD&D Game System",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
